CREATE OR REPLACE FUNCTION has_valid_consent(p_recording_id uuid)
RETURNS boolean
LANGUAGE sql
STABLE
AS $$
  SELECT EXISTS (
    SELECT 1
    FROM consents
    WHERE recording_id = p_recording_id
  );
$$;

