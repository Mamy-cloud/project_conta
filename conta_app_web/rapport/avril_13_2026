CREATE TYPE segment_status AS ENUM (
  'pending',
  'in_progress',
  'validated',
  'inaudible',
  'skipped'
);


CREATE TABLE segments (
  id                  uuid            PRIMARY KEY DEFAULT gen_random_uuid(),
  recording_id        uuid            NOT NULL REFERENCES recordings(id) ON DELETE RESTRICT,
  start_ms            integer         NOT NULL,
  end_ms              integer         NOT NULL,
  whisper_text        text,
  whisper_confidence  float           CHECK (whisper_confidence >= 0 AND whisper_confidence <= 1),
  corrected_text      text,
  status              segment_status  NOT NULL DEFAULT 'pending',
  is_gold             boolean         NOT NULL DEFAULT false,
  validated_by        uuid            REFERENCES users(id) ON DELETE SET NULL,
  validated_at        timestamptz,

  -- Contrainte : end_ms doit être supérieur à start_ms
  CONSTRAINT segments_valid_range CHECK (end_ms > start_ms),

  -- Contrainte : durée entre 30s et 90s
  CONSTRAINT segments_duration_range CHECK ((end_ms - start_ms) BETWEEN 30000 AND 90000)
);


ALTER TABLE segments ENABLE ROW LEVEL SECURITY;


CREATE INDEX segments_recording_id_idx  ON segments(recording_id);
CREATE INDEX segments_status_idx        ON segments(status);
CREATE INDEX segments_validated_by_idx  ON segments(validated_by);
CREATE INDEX segments_is_gold_idx       ON segments(is_gold) WHERE is_gold = true;

