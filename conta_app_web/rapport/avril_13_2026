ALTER TABLE validations ENABLE ROW LEVEL SECURITY;


CREATE INDEX validations_segment_id_idx ON validations(segment_id);
CREATE INDEX validations_user_id_idx    ON validations(user_id);
CREATE INDEX validations_vote_idx       ON validations(vote);


CREATE OR REPLACE FUNCTION check_gold_consensus(p_segment_id uuid)
RETURNS void
LANGUAGE plpgsql
AS $$
DECLARE
  v_count integer;
  v_top_text text;
BEGIN
  
  SELECT corrected_text, COUNT(*) AS cnt
  INTO v_top_text, v_count
  FROM validations
  WHERE segment_id = p_segment_id
    AND vote = 'up'
    AND corrected_text IS NOT NULL
  GROUP BY corrected_text
  ORDER BY cnt DESC
  LIMIT 1;

  
  IF v_count >= 2 THEN
    UPDATE segments
    SET
      is_gold        = true,
      corrected_text = v_top_text,
      status         = 'validated',
      validated_at   = now()
    WHERE id = p_segment_id;
  END IF;
END;
$$;


CREATE OR REPLACE FUNCTION trigger_check_gold()
RETURNS trigger
LANGUAGE plpgsql
AS $$
BEGIN
  PERFORM check_gold_consensus(NEW.segment_id);
  RETURN NEW;
END;
$$;

CREATE TRIGGER after_validation_insert
  AFTER INSERT ON validations
  FOR EACH ROW
  EXECUTE FUNCTION trigger_check_gold();


